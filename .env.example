# --- API Configuration ---
# Xiaomi ASR (MiMo-V2-Omni) & OpenAI (MiMo-V2-Pro)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
OPENAI_MODEL=mimo-v2-pro
XIAOMI_OMNI_MODEL=mimo-v2-omni

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./meeting_ai.db

# --- KnowledgeBase (KB sync target, Optional) ---
# Set credentials to enable the "Sync to KB" feature on meeting detail page.
# Base URL WITHOUT a trailing /api segment — endpoints append it themselves.
KNOWLEDGE_BASE_BASE_URL=https://kb.example.com
KNOWLEDGE_BASE_USERNAME=
KNOWLEDGE_BASE_PASSWORD=
KNOWLEDGE_BASE_DEFAULT_DOC_TYPE=meeting_notes

# --- Feishu Integration (Optional) ---
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_BITABLE_APP_TOKEN=basxxx
FEISHU_BITABLE_TABLE_ID=tblxxx

# --- Server Settings ---
PORT=8000
DEBUG=False
UPLOAD_DIR=uploads
